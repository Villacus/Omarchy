#!/usr/bin/env python3
"""Fetch all tracks from Navidrome and create/update a local TOML playlist for cliamp."""

import hashlib
import json
import os
import secrets
import sys
import tomllib
import urllib.parse
import urllib.request
import urllib.error
from pathlib import Path

CONFIG_DIR = Path.home() / ".config" / "cliamp"
CONFIG_PATH = CONFIG_DIR / "config.toml"
PLAYLIST_DIR = CONFIG_DIR / "playlists"
PLAYLIST_PATH = PLAYLIST_DIR / "all-songs.toml"

PAGE_SIZE = 500


def load_config():
    with open(CONFIG_PATH, "rb") as f:
        cfg = tomllib.load(f)
    nd = cfg.get("navidrome", {})
    url = nd.get("url", "").rstrip("/")
    user = nd.get("user", "")
    password = nd.get("password", "")
    if not url or not user or not password:
        print("error: Navidrome config not found in", CONFIG_PATH, file=sys.stderr)
        sys.exit(1)
    return url, user, password


def subsonic_url(base, user, password, endpoint, params=None):
    if params is None:
        params = {}
    salt = secrets.token_hex(8)
    token = hashlib.md5((password + salt).encode()).hexdigest()
    params.update({"u": user, "t": token, "s": salt, "v": "1.0.0", "c": "cliamp", "f": "json"})
    qs = "&".join(f"{k}={urllib.parse.quote(str(v))}" for k, v in params.items())
    return f"{base}/rest/{endpoint}?{qs}"


def subsonic_get(base, user, password, endpoint, params=None):
    url = subsonic_url(base, user, password, endpoint, params)
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read().decode())


def stream_url(base, user, password, track_id):
    return subsonic_url(base, user, password, "stream", {"id": track_id, "format": "raw"})


def get_all_albums(base, user, password):
    albums = []
    offset = 0
    while True:
        data = subsonic_get(base, user, password, "getAlbumList2",
                            {"type": "newest", "offset": str(offset), "size": str(PAGE_SIZE)})
        batch = data.get("subsonic-response", {}).get("albumList2", {}).get("album", [])
        if not batch:
            break
        albums.extend(batch)
        offset += len(batch)
        if len(batch) < PAGE_SIZE:
            break
    return albums


def get_album_tracks(base, user, password, album_id):
    data = subsonic_get(base, user, password, "getAlbum", {"id": album_id})
    return data.get("subsonic-response", {}).get("album", {}).get("song", [])


def toml_str(s):
    """Escape a string for TOML basic string format."""
    s = s.replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n").replace("\t", "\\t")
    return f'"{s}"'


def main():
    url, user, password = load_config()

    print("Fetching all albums from Navidrome...", file=sys.stderr)
    albums = get_all_albums(url, user, password)
    print(f"  Found {len(albums)} albums", file=sys.stderr)

    tracks = []
    for i, album in enumerate(albums):
        album_id = album["id"]
        album_name = album.get("name", "Unknown")
        artist = album.get("artist", "Unknown")
        print(f"  [{i+1}/{len(albums)}] {artist} - {album_name}", file=sys.stderr)
        try:
            song_list = get_album_tracks(url, user, password, album_id)
        except Exception as e:
            print(f"    warning: failed to fetch tracks: {e}", file=sys.stderr)
            continue
        for song in song_list:
            tracks.append({
                "path": stream_url(url, user, password, song["id"]),
                "title": song.get("title", "Unknown"),
                "artist": song.get("artist", ""),
                "album": song.get("album", ""),
                "genre": song.get("genre", ""),
                "year": song.get("year", 0),
                "track_number": song.get("track", 0),
                "duration_secs": song.get("duration", 0),
            })

    total = len(tracks)
    print(f"\nTotal tracks: {total}", file=sys.stderr)

    PLAYLIST_DIR.mkdir(parents=True, exist_ok=True)
    with open(PLAYLIST_PATH, "w") as f:
        f.write("# Generated by cliamp-sync-all\n")
        f.write(f"# Total tracks: {total}\n")
        for t in tracks:
            f.write(f"\n[[track]]\n")
            f.write(f"path = {toml_str(t['path'])}\n")
            f.write(f"title = {toml_str(t['title'])}\n")
            if t["artist"]:
                f.write(f"artist = {toml_str(t['artist'])}\n")
            if t["album"]:
                f.write(f"album = {toml_str(t['album'])}\n")
            if t.get("genre"):
                f.write(f"genre = {toml_str(t['genre'])}\n")
            if t["year"]:
                f.write(f"year = {t['year']}\n")
            if t["track_number"]:
                f.write(f"track_number = {t['track_number']}\n")
            if t["duration_secs"]:
                f.write(f"duration_secs = {t['duration_secs']}\n")

    print(f"\nPlaylist saved to {PLAYLIST_PATH}", file=sys.stderr)
    print(f"Run: cliamp --shuffle --auto-play --playlist all-songs", file=sys.stderr)


if __name__ == "__main__":
    main()
