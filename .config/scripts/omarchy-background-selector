#!/bin/bash

theme_name=$(cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null)
current_background=$(readlink -f "$HOME/.config/omarchy/current/background" 2>/dev/null)

# Mostrar el selector de fondo
selected=$(omarchy-menu-images \
  --selected "$current_background" \
  "$HOME/.config/omarchy/current/theme/backgrounds" \
  "$HOME/.config/omarchy/backgrounds/$theme_name" \
  "$HOME/.config/omarchy/themes/wallpaper-engine/backgrounds")

if [[ -z "$selected" ]]; then
  exit 0
fi

# Obtener lista de monitores
monitors=$(hyprctl monitors -j | jq -r '.[].name')

if [[ -z "$monitors" ]]; then
  echo "No monitors found"
  exit 1
fi

# Mostrar selector de monitor
selected_monitor=$(omarchy-menu-select "Select monitor" $monitors)

if [[ -z "$selected_monitor" ]]; then
  exit 0
fi

# Aplicar fondo al monitor seleccionado
if [[ "$selected" == *"wallpaper-engine"* ]]; then
  WALLPAPER_ID=$(basename "$selected" | sed 's/^wallpaper_//;s/\.[^.]*$//')
  ~/.config/scripts/set-wallpaper-engine "$WALLPAPER_ID" "$selected_monitor"
  ENTRY="$selected_monitor:wallpaper-engine:$WALLPAPER_ID"
else
  omarchy-theme-bg-set "$selected" "$selected_monitor"
  ENTRY="$selected_monitor:static:$selected"
fi

# Guardar asignacion para restaurar al encender
CONFIG_FILE="$HOME/.config/omarchy/current/wallpapers.conf"
sed -i "/^$selected_monitor:/d" "$CONFIG_FILE" 2>/dev/null
echo "$ENTRY" >> "$CONFIG_FILE"
